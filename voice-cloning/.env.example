# A key WITH the voice:clone scope. pyai_test_ is fine for trying it.
PYAI_API_KEY=pyai_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional display name for the cloned voice.
CLONE_NAME=PyAI example clone
# Optional: clone a REAL person instead of the synthesized sample. Use a clean,
# single-speaker recording, >=10s, recorded at >=24 kHz full-band (not a phone
# clip, not upsampled). Recommended to also set KEEP_CLONE=1.
# REFERENCE_AUDIO=./me.wav
# Keep the clone after the run (default: it's deleted so runs don't pile up).
# KEEP_CLONE=1
# Leave unset in production (defaults to https://api.pyai.com).
# PYAI_BASE_URL=https://api.pyai.com
