# Copy to .env and fill in. .env is git-ignored.

# Your PyAI key (stays server-side; used only to mint short-lived browser tokens).
# A sandbox key works for trying it out: https://console.pyai.com
PYAI_API_KEY=pyai_test_...

# Optional: a voice_id from GET /v1/voices. Omit for the account default.
PYAI_VOICE=

# Optional: the agent's behavior, sent in the configure frame.
PERSONA=You are a friendly assistant for this website. Keep answers short and spoken-friendly.

# Origins allowed to mint a token (and that the token is locked to). Comma-separated.
# Leave empty in local dev to allow the request origin / localhost.
ALLOWED_ORIGINS=

# Minted token lifetime in seconds (15–600). Short by design.
SESSION_TTL_SECONDS=60

# Server port.
PORT=8080

# Optional: override the API base (defaults to https://api.pyai.com).
PYAI_BASE_URL=https://api.pyai.com
