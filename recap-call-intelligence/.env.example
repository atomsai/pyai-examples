# A key with scopes: hear:transcribe + transcribe:jobs. pyai_test_ is fine.
PYAI_API_KEY=pyai_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: analyze your own recording instead of the synthesized sample call.
# AUDIO_FILE=./call.wav
# AUDIO_URL=https://example.com/call.mp3
# Optional: pin the two synthesized-call voices (default: first two from /v1/voices).
# PYAI_VOICE_A=stock_emma_en_gb
# PYAI_VOICE_B=stock_sarah_style2
# Leave unset in production (defaults to https://api.pyai.com).
# PYAI_BASE_URL=https://api.pyai.com
