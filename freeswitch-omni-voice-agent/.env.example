# A pyai_test_ / pyai_live_ key with the omni:session scope. Server-side only.
PYAI_API_KEY=pyai_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional voice id from GET /v1/voices (omit for the default voice).
# PYAI_VOICE=stock_emma_en_gb
# Agent behavior (sent in the configure frame).
# PERSONA=You are a warm, concise front-desk agent for Acme.
# Omni audio rate: 16000 for an L16/16k FreeSWITCH leg, 8000 for a G.711 leg.
# OMNI_RATE=16000
# This bridge's WebSocket port (point mod_audio_stream at ws://<host>:PORT/fs).
# PORT=8080
# Leave unset in production (defaults to wss://api.pyai.com).
# PYAI_BASE_URL=wss://api.pyai.com
