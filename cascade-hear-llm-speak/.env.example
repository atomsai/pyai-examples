# A sandbox key is fine: pyai_test_...  (keys are opaque; never parsed)
PYAI_API_KEY=pyai_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional voice id for Speak (see GET /v1/voices).
PYAI_VOICE=stock_sarah_style2
# Optional: transcribe your own file instead of a synthesized sample.
# INPUT_AUDIO=./call.wav
# Optional: change the sample question that gets synthesized + transcribed.
# SAMPLE_QUESTION=What are your opening hours this weekend?
# Leave unset in production (defaults to https://api.pyai.com).
# PYAI_BASE_URL=https://api.pyai.com
