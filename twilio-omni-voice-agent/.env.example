# --- PyAI ---
# A sandbox key works for testing: pyai_test_...  (keys are opaque; never parsed)
PYAI_API_KEY=pyai_test_xxxxxxxxxxxxxxxxxxxxxxxx
# An Omni agent id (any opaque label authorized by your key's org).
PYAI_AGENT_ID=support-bot
# Optional voice id (see GET /v1/voices). Omit for the agent's default.
PYAI_VOICE=stock_sarah_style2
# Leave unset in production (defaults to https://api.pyai.com).
# PYAI_BASE_URL=https://api.pyai.com

# --- Server ---
PORT=8080
# The public host Twilio can reach (e.g. your ngrok host, no scheme).
# If unset, the server uses the Host header Twilio sends.
# PUBLIC_HOST=your-subdomain.ngrok.app

# --- Twilio (only needed for "transfer to a human") ---
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# HUMAN_NUMBER=+15551230000
