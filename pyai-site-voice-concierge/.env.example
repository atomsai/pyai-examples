# --- Required -------------------------------------------------------------
# A pyai_live_ / pyai_test_ key with the omni:session scope. SERVER-SIDE ONLY:
# in direct mode it is used to MINT short-lived browser tokens; it never ships
# to the page in either mode.
PYAI_API_KEY=pyai_live_xxx

# --- Connect mode ---------------------------------------------------------
# direct  = (preferred) mint an ephemeral session token; browser connects to
#           PyAI directly. This server stays out of the audio path.
# broker  = relay the realtime socket through this server.
CONNECT_MODE=direct

# Lifetime of a minted session token, seconds (direct mode). Max 600.
SESSION_TTL_SECONDS=60

# --- Optional -------------------------------------------------------------
# Opaque tag echoed to your kb_endpoint. Legacy alias: PYAI_AGENT_ID.
PYAI_SESSION_LABEL=pyai-site-concierge
# A voice_id from GET /v1/voices. Omit for the default voice.
PYAI_VOICE=
# Override the API base (testing only). Default https://api.pyai.com.
PYAI_BASE_URL=https://api.pyai.com
# This server's port.
PORT=8787

# --- Live grounding (recommended) -----------------------------------------
# Public https URL of THIS server's /kb that the PyAI engine calls each turn,
# and the bearer token it must present. Tunnel /kb in local dev (e.g. ngrok).
KB_PUBLIC_URL=
KB_TOKEN=

# --- Origins & limits -----------------------------------------------------
# Comma-separated browser origins. In direct mode this locks the minted token's
# origin; in broker mode it gates the /voice upgrade. Empty = any (dev only).
ALLOWED_ORIGINS=
# Cap on concurrent live broker sessions (broker mode only).
MAX_CONCURRENT_SESSIONS=25
