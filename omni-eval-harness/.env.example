# ---------------------------------------------------------------------------
# omni-eval-harness — environment
#
# OFFLINE mode (the default) needs NONE of these. It replays recorded session
# fixtures from fixtures/ and scores them with no network and no key.
#
# LIVE mode (`npm run live`) connects to the real PyAI surfaces and is GATED:
# if PYAI_API_KEY is absent the harness skips the live run cleanly (dormant
# gate) and exits 0, so the same command is safe to wire into CI.
# ---------------------------------------------------------------------------

# A sandbox key is perfect here. Keys are opaque — never parse/split/decode them.
# Without this set, `--live` is skipped (dormant gate).
PYAI_API_KEY=pyai_test_...

# The Omni agent to drive. An opaque label authorized by your key's org.
# Falls back to the scenario's `agent_id`, then to "harness-agent".
PYAI_AGENT_ID=clinic-front-desk

# Voice used to SYNTHESIZE the synthetic caller's turns (Speak). Any catalog id.
PYAI_VOICE=stock_sarah_style2

# Override only for staging/self-host. Defaults to https://api.pyai.com.
# PYAI_BASE_URL=https://api.pyai.com
