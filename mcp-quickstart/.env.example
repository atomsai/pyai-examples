# Optional. If set, the demo (and the MCP server) use this key and skip minting a
# sandbox key. Leave it blank to let the server mint a free pyai_test_ key with
# no email/card via the create_sandbox_key tool.
PYAI_API_KEY=

# Optional. Defaults to https://api.pyai.com.
PYAI_BASE_URL=https://api.pyai.com
